# BA-Bridge — Environment Variables
# Kopieren nach .env und ausfüllen

# Railway Postgres (Shadow-DB) — aus Railway Dashboard kopieren
DATABASE_URL=postgresql://user:password@host:port/dbname

# Anthropic API Key (Claude NER)
ANTHROPIC_API_KEY=sk-ant-...

# Interner API-Key (Argo-Backend → Bridge) — beliebiger String, leer = kein Schutz
BRIDGE_API_KEY=

# Rate-Limit Bundesanzeiger (Sekunden zwischen Requests)
BA_RATE_LIMIT_SEC=3.0

# Cron-Schedule (UTC)
CRON_HOUR=3
CRON_MINUTE=0
